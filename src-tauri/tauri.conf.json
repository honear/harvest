{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harvest",
  "version": "0.1.0",
  "identifier": "co.honear.harvest",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Harvest",
        "width": 980,
        "height": 760,
        "minWidth": 760,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "copyright": "© 2026 Rolando",
    "publisher": "Rolando",
    "shortDescription": "Verified media ingest",
    "longDescription": "Harvest copies footage and files from cards or folders to one or more destinations and verifies every byte — read once, write everywhere, prove it landed intact.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
